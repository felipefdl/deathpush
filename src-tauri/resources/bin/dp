#!/bin/bash
# DeathPush CLI launcher (macOS / Linux)
# macOS: opens via deep link URL (deathpush://). Linux: launches the binary directly.

set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$0")"

TARGET="${1:-.}"

# Convert relative paths to absolute
if [[ "$TARGET" != /* ]]; then
  TARGET="$(cd "$TARGET" 2>/dev/null && pwd)" || {
    echo "Error: Directory '$1' does not exist" >&2
    exit 1
  }
fi

case "$(uname)" in
  Darwin)
    # macOS: use deep link URL -- works whether app is running or not
    open "deathpush://$TARGET"
    ;;
  *)
    # Linux: resources/bin/dp sits alongside the binary
    APP_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_PATH")")")"
    BINARY="$APP_DIR/deathpush"
    if [ ! -x "$BINARY" ]; then
      BINARY="$(dirname "$(dirname "$SCRIPT_PATH")")/../deathpush"
      BINARY="$(cd "$(dirname "$BINARY")" && pwd)/$(basename "$BINARY")"
    fi
    if [ ! -x "$BINARY" ]; then
      echo "Error: DeathPush binary not found at $BINARY" >&2
      echo "Please reinstall the CLI tool from DeathPush > Install Command Line Tool..." >&2
      exit 1
    fi
    nohup "$BINARY" "$TARGET" >/dev/null 2>&1 &
    disown
    ;;
esac
