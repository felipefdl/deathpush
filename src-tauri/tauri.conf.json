{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeathPush",
  "mainBinaryName": "deathpush",
  "version": "0.1.1",
  "identifier": "com.felipefdl.deathpush",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeathPush",
        "width": 1400,
        "height": 900,
        "minWidth": 640,
        "minHeight": 480,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": [30, 30, 30, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["deathpush"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGNjkyMjhEQkE4NUJEMDAKUldRQXZZVzZqU0pwTHh2VGlkTzg4UHNxdGFyb09BOEJDRzl5UnNrYmRzVWJXMGVJbGZXZnRHMk8K",
      "endpoints": [
        "https://github.com/felipefdl/deathpush/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["resources/bin/dp", "resources/bin/dp.cmd"],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/dp": "scripts/dp-linux"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/dp": "scripts/dp-linux"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
