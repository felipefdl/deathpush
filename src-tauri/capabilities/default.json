{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "main-*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "dialog:allow-message",
    "shell:default",
    "core:window:allow-start-dragging",
    "deep-link:default",
    "window-state:default",
    "updater:default",
    "process:default"
  ]
}
