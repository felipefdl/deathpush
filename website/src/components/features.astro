---
const features = [
  {
    name: "Monaco diffs",
    detail: "Syntax highlighting, side-by-side or unified, inline editing",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    name: "Visual staging",
    detail: "File-level and hunk-level staging with one click",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  },
  {
    name: "Branches",
    detail: "Create, switch, merge, rebase, rename, delete, push, pull",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>`,
  },
  {
    name: "Image diffs",
    detail: "Side-by-side, overlay, and difference modes",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  },
  {
    name: "Blame + history",
    detail: "Line-by-line annotations, file history timeline",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    name: "Terminal",
    detail: "Built-in PTY terminal, run anything without switching windows",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
  {
    name: "Stash, tags, cherry-pick",
    detail: "The git operations you actually use",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    name: "Multi-window",
    detail: "One window per repo, each with its own state",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
  {
    name: "Themes",
    detail: "Dark, light, high-contrast",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  },
  {
    name: "Native Swift + Rust",
    detail: "No Electron. Fast startup, low memory",
    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
];
---

<section id="features" class="features section">
  <div class="container">
    <div class="features-header">
      <h2 class="text-heading">What's inside</h2>
    </div>
    <div class="features-list">
      {features.map((f, i) => (
        <div class="feature-row" style={`animation-delay: ${i * 0.04}s`}>
          <span class="feature-icon" set:html={f.icon} />
          <span class="feature-name">{f.name}</span>
          <span class="feature-detail">{f.detail}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .features-list {
    max-width: 720px;
    margin: 0 auto;
  }

  .feature-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.2s, border-color 0.2s;
    border-radius: 2px;
    opacity: 0;
    animation: row-in 0.35s ease-out forwards;
  }

  .feature-row:first-child {
    border-top: 1px solid var(--color-border);
  }

  .feature-row:hover {
    background: rgba(232, 217, 189, 0.02);
  }

  .feature-row:hover .feature-icon {
    color: var(--color-accent);
    opacity: 1;
  }

  .feature-row:hover .feature-name {
    color: var(--color-accent);
  }

  @keyframes row-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @media (min-width: 640px) {
    .feature-row {
      flex-direction: row;
      align-items: center;
      gap: var(--space-md);
    }
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    color: var(--color-text-muted);
    opacity: 0.5;
    transition: color 0.2s, opacity 0.2s;
  }

  .feature-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 160px;
    transition: color 0.2s;
  }

  .feature-detail {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
</style>
