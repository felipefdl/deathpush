---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/logo-white.png" alt="DeathPush" width="24" height="24" />
        <span class="footer-name">DeathPush</span>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://github.com/felipefdl/deathpush" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://github.com/felipefdl/deathpush/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a>
        <a href="https://github.com/felipefdl/deathpush/releases" target="_blank" rel="noopener noreferrer">Changelog</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p class="copyright">&copy; {year} DeathPush. All rights reserved.</p>
      <p class="tagline">Made with Rust and bad decisions.</p>
    </div>
    <div class="footer-also">
      <p class="footer-also-title">Also by this developer</p>
      <div class="footer-also-apps">
        <a href="https://mqtee.app" target="_blank" rel="noopener noreferrer" class="footer-also-app">
          <img src="/mqtee-logo.svg" alt="MQTee" width="18" height="18" class="footer-also-icon" />
          <span class="footer-also-name">MQTee</span>
          <span class="footer-also-sep">&mdash;</span>
          <span class="footer-also-tagline">Native MQTT client for Apple platforms</span>
        </a>
        <a href="https://reqeast.app" target="_blank" rel="noopener noreferrer" class="footer-also-app">
          <img src="/reqeast-logo.svg" alt="Reqeast" width="18" height="18" class="footer-also-icon" />
          <span class="footer-also-name">Reqeast</span>
          <span class="footer-also-sep">&mdash;</span>
          <span class="footer-also-tagline">Native API client for Apple platforms</span>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-2xl);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-brand img {
    border-radius: 4px;
  }

  .footer-name {
    font-weight: 600;
    font-size: var(--text-sm);
  }

  .footer-links {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-links a {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: color 0.2s, border-color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .copyright {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .tagline {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .footer-also {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-also-title {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .footer-also-apps {
    display: inline-grid;
    grid-template-columns: 18px max-content max-content auto;
    align-items: center;
    text-align: left;
    gap: var(--space-xs) var(--space-sm);
  }

  .footer-also-app {
    display: contents;
    color: var(--color-text-muted);
  }

  .footer-also-app:hover .footer-also-icon {
    opacity: 0.8;
  }

  .footer-also-app:hover .footer-also-name,
  .footer-also-app:hover .footer-also-tagline,
  .footer-also-app:hover .footer-also-sep {
    color: var(--color-text);
  }

  .footer-also-icon {
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .footer-also-sep {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-also-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-also-tagline {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
</style>
